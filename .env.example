# ── Copy this file to `.env` and fill in real values ──────────────────
# (`.env` itself is gitignored — never commit real secrets.)

# PostgreSQL connection string — use a free Neon database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth — secret used to sign/verify JWT sessions and getToken().
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="your-long-random-secret"

# The app's base URL.
#   Local:  http://localhost:3000
#   Vercel: your deployed URL, e.g. https://pulsefeed.vercel.app
NEXTAUTH_URL="http://localhost:3000"
